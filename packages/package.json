{
  "name": "thunder-text-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Thunder Text Platform (ThunderText + ACE)",
  "workspaces": [
    "packages/shared-backend",
    "packages/shared-ui",
    "packages/thundertext-app",
    "packages/ace-app"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=thundertext-app",
    "dev:thundertext": "npm run dev --workspace=thundertext-app",
    "dev:ace": "npm run dev --workspace=ace-app",
    "build": "npm run build --workspaces --if-present",
    "build:thundertext": "npm run build --workspace=thundertext-app",
    "build:ace": "npm run build --workspace=ace-app",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf packages/*/node_modules packages/*/.next packages/*/dist node_modules"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Thunder Text Team",
  "license": "UNLICENSED"
}
